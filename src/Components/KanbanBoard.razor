@using AIDA.M365.Models
@using AIDA.M365.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Logging
@using MudBlazor
@inject IEventCommandCenterService EventCommandCenterService
@inject ILogger<KanbanBoard> Logger

<MudPaper Class="position-relative pa-0" Elevation="0">
    <MudOverlay Visible="@_isBusy" DarkBackground="true" Absolute="true" ZIndex="10">
        <MudStack AlignItems="AlignItems.Center" JustifyContent="Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">@_busyMessage</MudText>
        </MudStack>
    </MudOverlay>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">
            @_errorMessage
        </MudAlert>
    }

    <MudDropContainer T="KanbanEventCard"
                      Items="Cards"
                      ItemsSelector="@((item, zoneKey) => item.SectionKey == zoneKey)"
                      ItemUpdated="HandleItemUpdatedAsync"
                      Class="d-flex flex-column gap-4">
        <ChildContent>
            <MudGrid>
                @foreach (var sectionDef in Sections)
                {
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-4" Elevation="1">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                                <MudText Typo="Typo.h6" Class="flex-grow-1">@sectionDef.Title</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="() => DeleteSectionAsync(sectionDef)"
                                               title="Delete this section" />
                            </MudStack>
                            <MudDropZone T="KanbanEventCard"
                                         Identifier="@sectionDef.Key"
                                         Class="mt-2 min-height-300" />
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </ChildContent>

        <ItemRenderer Context="card">
            <MudPaper Class="pa-3 mb-2" Outlined="true" Style="@GetCardStyle(card)">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.subtitle2" Class="flex-grow-1">@card.Subject</MudText>
                        @if (card.IsLinkedToDynamics)
                        {
                            <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Dynamics</MudChip>
                        }
                    </MudStack>
                    <MudText Typo="Typo.caption">
                        @card.StartUtc.ToLocalTime().ToString("g") - @card.EndUtc.ToLocalTime().ToString("g")
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(card.SmartSummary))
                    {
                        <MudText Typo="Typo.body2">@card.SmartSummary</MudText>
                    }
                    @if (card.ActionItems.Count > 0)
                    {
                        <MudList Dense="true" Class="py-0">
                            @foreach (var actionItem in card.ActionItems)
                            {
                                <MudListItem Dense="true">@actionItem</MudListItem>
                            }
                        </MudList>
                    }
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.AutoAwesome"
                               Disabled="@_isBusy"
                               OnClick="@(() => SummarizeCardAsync(card))">
                        Smart Summarize
                    </MudButton>
                </MudStack>
            </MudPaper>
        </ItemRenderer>
    </MudDropContainer>
</MudPaper>


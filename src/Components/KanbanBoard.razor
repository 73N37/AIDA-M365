    private static (DateTimeOffset StartUtc, DateTimeOffset EndUtc) RecalculateTimes(
        KanbanEventCard card,
        KanbanSectionDefinition destinationSection)
    {
        var duration = card.Duration;
        var baseDayUtc = DateTimeOffset.UtcNow.Date.AddDays(destinationSection.DayOffsetFromTodayUtc);
        var newStartUtc = baseDayUtc
            .AddHours(destinationSection.StartHourUtc)
            .AddMinutes(destinationSection.StartMinuteUtc);

        return (newStartUtc, newStartUtc.Add(duration));
    }

    private async Task DeleteSectionAsync(KanbanSectionDefinition section)
    {
        if (SectionDeleted.HasDelegate)
        {
            await SectionDeleted.InvokeAsync(section);
        }
    }

    private async Task SummarizeCardAsync(KanbanEventCard card)
    {
        _isBusy = true;
        _busyMessage = "Generating action items...";
        _errorMessage = null;

        try
        {
            var result = await EventCommandCenterService.SummarizeCardAsync(card);
            if (!result.Succeeded)
            {
                _errorMessage = result.ErrorMessage;
                return;
            }

            card.SmartSummary = result.Summary;
            card.ActionItems = result.ActionItems;

            if (CardUpdated.HasDelegate)
            {
                await CardUpdated.InvokeAsync(card);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Smart Summarize failed.";
            Logger.LogError(ex, "Failed to summarize event {EventId}", card.GraphEventId);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string? GetCardStyle(KanbanEventCard card) =>
        string.IsNullOrWhiteSpace(card.ColorHex)
            ? null
            : $"border-left: 4px solid {card.ColorHex};";
}
